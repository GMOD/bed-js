{
  "name": "@gmod/bed",
  "version": "2.1.10",
  "description": "A BED file format parser with autoSql support",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GMOD/bed-js.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    "import": "./esm/index.js",
    "require": "./dist/index.js"
  },
  "author": {
    "name": "Colin Diesh",
    "email": "colin.diesh@gmail.com",
    "url": "https://github.com/cmdcolin"
  },
  "homepage": "https://github.com/GMOD/bed-js",
  "bugs": {
    "url": "https://github.com/GMOD/bed-js/issues"
  },
  "files": [
    "dist",
    "esm",
    "src"
  ],
  "scripts": {
    "test": "vitest",
    "clean": "rimraf dist esm",
    "format": "prettier --write .",
    "lint": "eslint --report-unused-disable-directives --max-warnings 0",
    "prebuild": "pnpm clean",
    "build:esm": "tsc --outDir esm",
    "build:es5": "tsc --module commonjs --moduleResolution bundler --outDir dist",
    "postbuild:es5": "echo '{\"type\": \"commonjs\"}' > dist/package.json",
    "preversion": "pnpm lint && pnpm test --run && pnpm build",
    "postversion": "git push --follow-tags",
    "build": "pnpm build:esm && pnpm build:es5",
    "generate": "pegjs -o src/autoSql.js autoSql.pegjs && node -e \"const fs=require('fs');const f='src/autoSql.js';fs.writeFileSync(f,fs.readFileSync(f,'utf8').replace(/module\\.exports\\s*=\\s*\\{[^}]+\\};?/,'export { peg\\$SyntaxError as SyntaxError, peg\\$parse as parse };\\nexport default { SyntaxError: peg\\$SyntaxError, parse: peg\\$parse };'))\"",
    "version": "standard-changelog && git add CHANGELOG.md"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.2.1",
    "eslint-plugin-import-x": "^4.16.2",
    "pegjs": "^0.10.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "standard-changelog": "^7.0.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "bed",
    "autosql",
    "genomics",
    "bionode",
    "biojs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@jbrowse/quick-lru": "^7.3.5"
  }
}
