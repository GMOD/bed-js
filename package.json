{
  "name": "@gmod/bed",
  "version": "2.2.1",
  "description": "A BED file format parser with autoSql support",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GMOD/bed-js.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    "import": "./esm/index.js",
    "require": "./dist/index.js"
  },
  "author": {
    "name": "Colin Diesh",
    "email": "colin.diesh@gmail.com",
    "url": "https://github.com/cmdcolin"
  },
  "homepage": "https://github.com/GMOD/bed-js",
  "bugs": {
    "url": "https://github.com/GMOD/bed-js/issues"
  },
  "files": [
    "dist",
    "esm",
    "src"
  ],
  "scripts": {
    "test": "vitest",
    "clean": "rimraf dist esm",
    "format": "prettier --write .",
    "lint": "eslint --report-unused-disable-directives --max-warnings 0",
    "prebuild": "pnpm clean",
    "build:esm": "tsc --outDir esm",
    "build:es5": "tsc --module commonjs --moduleResolution bundler --outDir dist",
    "postbuild:es5": "echo '{\"type\": \"commonjs\"}' > dist/package.json",
    "preversion": "pnpm lint && pnpm test --run && pnpm build",
    "postversion": "git push --follow-tags",
    "build": "pnpm build:esm && pnpm build:es5",
    "generate": "peggy --format es -o src/autoSql.js autoSql.pegjs",
    "version": "standard-changelog && git add CHANGELOG.md"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-plugin-import-x": "^4.16.2",
    "peggy": "^5.1.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "standard-changelog": "^7.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "bed",
    "autosql",
    "genomics",
    "bionode",
    "biojs"
  ],
  "publishConfig": {
    "access": "public"
  }
}
