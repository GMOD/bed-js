{
  "compilerOptions": {
    "moduleResolution": "bundler",
    "module": "esnext",
    "declaration": true,
    "target": "esnext",
    "outDir": "dist",
    "rootDir": "./src",
    "strict": true,
    "sourceMap": true,
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "rewriteRelativeImportExtensions": true,
    "esModuleInterop": true
  },
  "include": ["src"]
}
